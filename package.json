{
  "name": "js-reverse-mcp",
  "version": "1.0.0",
  "description": "Chrome浏览器JS逆向分析MCP工具 - CTF登录框加密逆向",
  "type": "module",
  "main": "./build/index.js",
  "bin": {
    "js-reverse-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node build/index.js",
    "inspector": "npx @modelcontextprotocol/inspector node build/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0",
    "puppeteer-core": "^23.0.0",
    "js-beautify": "^1.15.0",
    "acorn": "^8.14.0",
    "acorn-walk": "^8.3.0",
    "crypto-js": "^4.2.0",
    "node-forge": "^1.3.0",
    "mustache": "^4.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "@types/js-beautify": "^1.14.0",
    "@types/crypto-js": "^4.2.0",
    "@types/node-forge": "^1.3.0",
    "@types/mustache": "^4.2.0",
    "tsx": "^4.19.0"
  }
}
